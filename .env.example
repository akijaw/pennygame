# Naplace Coin 부스 API. 키는 브라우저 코드에 절대 넣지 마세요.
NAPLACE_COIN_BASE_URL=https://naplace-coin.vercel.app/api/v1
NAPLACE_COIN_API_KEY=

# 결제 추적/게임 토큰 HMAC 서명용. openssl rand -base64 48 등으로 생성 (최소 32자)
GAME_SIGNING_SECRET=

# 입장 참가비 (코인)
ENTRY_COIN_PRICE=100
# 승리 보상 (코인)
WIN_REWARD_COINS=200
# 카드 순서 보기 1회 가격 (코인) — 남은 52장 순서를 5초간 본인에게만 공개
PEEK_COIN_PRICE=50

# Preview/로컬 테스트에서만 true. Production은 false.
ALLOW_TEST_NICKNAME=false

# 실제 승리 보상 지급. 중복지급 방지 durable 원장을 붙인 뒤 Production에서만 true.
# 기본값 false는 검증만 하고 실제 코인은 지급하지 않는 모의 정산입니다.
ALLOW_REAL_REWARDS=false
